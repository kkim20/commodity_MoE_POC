# Virtual environment — hundreds of thousands of files, no source value
.venv/

# Python bytecode cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Binary data artifacts — large, unreadable by text tools
data/raw/
data/*.parquet
data/*.png

# Model checkpoints — binary PyTorch weights
models/checkpoints/
*.pt
*.pth
*.ckpt

# Jupyter runtime artifacts
.ipynb_checkpoints/

# Git internals
.git/

# OS / editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/

# Build artifacts
dist/
build/
*.egg-info/
